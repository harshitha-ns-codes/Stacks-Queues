    string PostfixToPrefix(string s)
    {

        stack<string> st;
        for(int i = n-1; i < s.length(); i--)
        {
            // Operand
            if((s[i] >= 'A' && s[i] <= 'Z') ||
               (s[i] >= 'a' && s[i] <= 'z') ||
               (s[i] >= '0' && s[i] <= '9'))
            {
                st.push(s[i]);
            }

            // Opening bracket
            else 
            {
                t1 = st.top(); st.pop();
                t2 = st.top(); st.pop();
                st.push(t1+t2+s[i]);
    }
return st.top();
};

