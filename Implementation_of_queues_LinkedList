Node* start , end ;
size = 0;

push(x)
{
Node* temp = new Node(x);
  if(start == NULL)
    start = end = temp;
else
  end = end->next;
size +=1;
}

pop()
{
  if(start == NULL) return 0;
  temp = start;
  start = start->next;
  delete temp;
  size -= 1;
}

top()
{
  if(start == NULL)
  return start->data;
}

size()
{
  return size;
}

